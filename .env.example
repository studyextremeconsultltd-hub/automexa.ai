# Paste your live payment links (Stripe Payment Link / PayPal / Klarna).
# Restart `npm run dev` after changing these values.

# Stripe Payment Link (Dashboard → Payment Links → Create)
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your_payment_link

# Optional plan-specific Stripe Payment Links
VITE_STRIPE_LINK_STARTER=
VITE_STRIPE_LINK_STANDARD=
VITE_STRIPE_LINK_CUSTOM=

# PayPal (Business / PayPal.Me or Checkout link)
VITE_PAYPAL_LINK=https://www.paypal.com/paypalme/yourbusiness

# Klarna hosted pay / merchant link
VITE_KLARNA_LINK=https://www.klarna.com/uk/

# Clearpay (Afterpay UK)
VITE_CLEARPAY_LINK=https://www.clearpay.co.uk/en-GB
