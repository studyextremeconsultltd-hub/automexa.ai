# Automexa — copy to `.env` (never commit secrets)

# Stripe secret key (Dashboard → Developers → API keys)
# Use sk_test_… locally, sk_live_… in production
# One key covers ALL products — no Payment Links needed
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Public site URL for success/cancel redirects (local default is fine)
SITE_URL=http://localhost:5173

# Optional: hosted checkout API (Cloudflare Worker). Leave blank to use local proxy.
# VITE_CHECKOUT_API_URL=https://your-checkout-worker.workers.dev

# ADEV professional web-developer widget (Cloudflare Worker)
VITE_ADEV_API_URL=https://adev-web-developer-plugin.adeelcolchester.workers.dev
